SyncAllFlds=50007;SyncAllFlds;50006
SyncThisFld=50008;SyncThisFld;50006
SyncDownloadAB=50009;SyncDownloadAB;50006 End Separator

; suppress whole App design menu, moving copy folder design to file_folder
AppDsn=50010;AppDsn;Tools Before ToolsServices Separator SubMenu Suppress
AppFldDsn=50011;AppFldDsn;50010 Suppress
