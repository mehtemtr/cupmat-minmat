
classes_root {
	;;============================
	;;			Addin
	;;============================
	key ".xla" = "Excel.Addin"
	key "Excel.Addin" = "Microsoft Excel Ýçine Ekle'si" {
		key "CLSID" = "{00020810-0000-0000-C000-000000000046}"
		key "DefaultIcon" = "|destdir|excel.exe,6"
		key "shell" = "open" {
			key "open" {
				key "command" = "|destdir|excel.exe /e"
				key "ddeexec" = "[open(\"%1\")]" {
					key "application" = "Excel"
					key "topic" = "system"
				}
			}
		}
	}

	;;============================
	;;		Application
	;;============================
	key "Excel.Application" = "Microsoft Excel Uygulamasý" {
		key "CLSID" = "{00020841-0000-0000-C000-000000000046}"
		key "CurVer" = "Excel.Application.5"
	}

	key "Excel.Application.5" = "Microsoft Excel Uygulamasý" {
		key "CLSID" = "{00020841-0000-0000-C000-000000000046}"
	}

	key noremove "CLSID" {
		key "{00020812-0000-0000-C000-000000000046}" = "Microsoft Excel Uygulamasý" {
			key "InprocHandler32" = "Ole32.dll"
			key "LocalServer32" = "|shortdestdir|excel.exe /automation"
			key "LocalServer" = "|shortdestdir|excel.exe /automation"
		}

		key "{00020841-0000-0000-C000-000000000046}" = "Microsoft Excel Uygulamasý" {
			key "InprocHandler32" = "Ole32.dll"
			key "ProgID" = "Excel.Application.5"
			key "VersionIndependentProgID" = "Excel.Application"
			key "LocalServer32" = "|shortdestdir|excel.exe /automation"
			key "LocalServer" = "|shortdestdir|excel.exe /automation"
		}
	}

	;;============================
	;;			Backup
	;;============================
	key ".xlk" = "Excel.Backup"
