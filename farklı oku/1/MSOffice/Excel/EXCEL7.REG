				key "ddeexec" = "[open(\"%1\")]" {
					key "application" = "Excel"
					key "topic" = "system"
				}
			}
			key "Print" {
				key "command" = "|destdir|excel.exe /e"
				key "ddeexec" = "[open(\"%1\")][print?()][close()]" {
					key "application" = "Excel"
					key "topic" = "system"
					key "ifexec" = "[open(\"%1\")][print?()][quit()]"
				}
			}
		}	;; Excel.Backup\Shell
	}

