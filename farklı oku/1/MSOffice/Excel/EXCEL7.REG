current_user {
	key noremove "Software" {
		key noremove "Microsoft" {
			key "Excel" {
				key forceremove "7.0" {
					key "Line Print" {
						valstr "BotMarg" = "2"
						valstr "Comment" = "Bu kýsým Lotus makrosu satýr yazdýrma ayarlarýný denetler."
						valstr "LeftMarg" = "4"
						valstr "Options" = "2"
						valstr "PgLen" = "66"
						valstr "Setup" = ""
						valstr "TopMarg" = "2"
						valstr "Rightmarg" = "76"
					}

					key "Microsoft Excel" {
						valstr "AutoFormat" = "1"
						valdword "AutoFormat Options" = "63"
						valstr "Maximized" = "3"
						valstr "Options5" = "129"
						valstr "Comment" = "Open=/f satýrlarý özel iţlevleri Ekle Ýţlev listesine ekler."
					}

					key "WK? Settings" {
						valstr "AFE" = "2"
						valstr "Gridlines" = "0"
						valstr "Load_Chart_Wnd" = "1"
						valstr "Monospace" = "1"
						valstr "Comment" = "Bu kýsým Lotus dosya açma ve kaydetme ayarlarýný denetler."
					}
				}	; 7.0
			}		; Excel
		}			; Microsoft
	}				; Software
}	; current_user

local_machine {
	key noremove "Software" {
		key noremove "Microsoft" {
			key noremove "Windows" {
				key noremove "CurrentVersion" {
					key noremove "App Paths" {
						key "EXCEL.EXE" = "|destdir|excel.exe"
					}
				}
			}
			
			key "New User Settings" {
				key forceremove "Excel" {
					key "7.0" {
						key "Line Print" {
							valstr "BotMarg" = "2"
							valstr "Comment" = "Bu kýsým Lotus makrosu satýr yazdýrma ayarlarýný denetler."
							valstr "LeftMarg" = "4"
							valstr "Options" = "2"
							valstr "PgLen" = "66"
							valstr "Setup" = ""
							valstr "TopMarg" = "2"
							valstr "Rightmarg" = "76"
						}

						key "Microsoft Excel" {
							valstr "AutoFormat" = "1"
							valdword "AutoFormat Options" = "63"
							valstr "Maximized" = "3"
							valstr "Options5" = "129"
							valstr "Comment" = "Open=/f satýrlarý özel iţlevleri Ekle Ýţlev listesine ekler."
						}

						key "WK? Settings" {
							valstr "AFE" = "2"
							valstr "Gridlines" = "0"
							valstr "Load_Chart_Wnd" = "1"
							valstr "Monospace" = "1"
							valstr "Comment" = "Bu kýsým Lotus dosya açma ve kaydetme ayarlarýný denetler."
						}
					}	; 7.0
				}		; Excel
			}		; New User Settings

			key "Microsoft Office" {
				key "95" {
					key "FileNew" {
						key "NFT" {
							key "Genel" {
								key "Blank Workboook" {
									valstr "name" = "Boţ Çalýţma Kitabý"
									valstr "type" = ".xls"
									valdword "flags" = "0"
									valdword "position" = "2"
									valdword "returncode" = "1"
									valstr "application" = "Excel"
									valstr "command" = "|destdir|excel.exe /e"
									valstr "ddeexec" = "[new()]"
									valstr "topic" = "system"
								}
							}	; General
						}		; NFT
					}			; FileNew
				}				; 95
			}					; Microsoft Office

		}			; Microsoft
	}				; Software
}	; local machine
