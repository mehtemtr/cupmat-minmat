	WndMess    = Windows 95 için Office Professional Kur baţlýyor, lütfen bekleyin...
	TmpDirSize = 2000
	TmpDirName = ~msstfqf.t
	CmdLine    = acmsetup /T setup.stf /S %s %s
	DrvModName = ACMSETUP
	DrvWinClass= Stuff-Shell
