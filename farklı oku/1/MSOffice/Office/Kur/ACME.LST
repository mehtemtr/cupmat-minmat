	FirstCabNum = 1
	InsertCDMsg	= Lütfen Microsoft Office Professional 95 CD 1'i yerleţtirin.
	InsertDiskMsg	= Lütfen Microsoft Office Professional 95 Disket 1'i yerleţtirin.

